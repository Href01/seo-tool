# DataForSEO - raw SEO data provider.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Postgres for shared cache, rate limit, keyword bank, projects, and rank tracking.
# Without it, the app runs in degraded mode: no cache, no bank, no tracking.
DATABASE_URL=

# Vercel Cron protection for /api/cron/check-ranks.
CRON_SECRET=

# Optional: this email is always created as admin. Without it, the first account is admin.
ADMIN_EMAIL=

# Auth placeholders for the future Google OAuth work.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET= # generate with: openssl rand -base64 32
