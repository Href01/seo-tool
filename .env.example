# DataForSEO — la matière première (crée un compte + dépôt ~50$ sur dataforseo.com)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Postgres pour le cache partagé (Neon gratuit : neon.tech). Optionnel au début :
# sans lui l'app tourne mais sans cache (chaque requête paie DataForSEO).
DATABASE_URL=

# Auth (Google OAuth) — crée une app sur console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=  # généré via: openssl rand -base64 32
